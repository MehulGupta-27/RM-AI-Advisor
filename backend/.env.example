# Groq API Configuration (GroqCloud - NOT Grok from x.ai)
# Get your free API key at: https://console.groq.com/
# Recommended models: llama-3.3-70b-versatile, mixtral-8x7b-32768
GROQ_API_KEY=your_groq_api_key_here
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# Database Configuration
DATABASE_URL=postgresql+asyncpg://username:password@localhost:5432/rm_advisory

# Cache Configuration
CACHE_TTL_SECONDS=90

# Compliance Configuration
COMPLIANCE_MAX_RETRIES=2

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:5173
